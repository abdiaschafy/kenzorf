# ─────────────────────────────────────────────────────────────
# KENZORF — variables d'environnement (copier en .env)
#   cp .env.example .env   puis adapter les valeurs
# ─────────────────────────────────────────────────────────────

# ─── Ports hôte (changer si déjà occupés, ex. cohabitation avec un autre projet) ─
POSTGRES_PORT=5432
API_PORT=8080
BACKOFFICE_PORT=4200

# ─── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=kenzorf
POSTGRES_USER=kenzorf
POSTGRES_PASSWORD=change-me-in-prod

# ─── API .NET ────────────────────────────────────────────────
# Development = test local clé en main (seed démo activé, paiement simulé, contrôles assouplis).
# PRODUCTION : passer à "Production" ET définir un Jwt__Key fort ci-dessous.
ASPNETCORE_ENVIRONMENT=Development
# Chaîne de connexion (le host "postgres" = nom du service docker)
ConnectionStrings__Default=Host=postgres;Port=5432;Database=kenzorf;Username=kenzorf;Password=change-me-in-prod

# JWT — OBLIGATOIRE : générer un secret long et aléatoire (≥ 32 caractères) !
#   Générer :  openssl rand -base64 48
#   ⚠️ L'API REFUSE de démarrer en Production si la clé est vide, < 32 caractères,
#      ou contient « change » (valeur de démo). docker compose échoue si Jwt__Key est absent.
Jwt__Issuer=kenzorf
Jwt__Audience=kenzorf
Jwt__Key=CHANGE-ME-openssl-rand-base64-48
Jwt__AccessMinutes=15
Jwt__RefreshDays=14

# ─── Paiement KPay (kpay.site) ───────────────────────────────
# Laisser vide = paiement désactivé (fail-closed en prod, FakeGateway en dev).
# Renseigner pour activer le vrai paiement mobile money / carte.
KPay__BaseUrl=https://kpay.site/api
KPay__ApiKey=
KPay__Secret=
KPay__WebhookSecret=

# ─── Back-office (Angular) ───────────────────────────────────
# URL de l'API vue par le navigateur. En local docker : http://localhost:8080/api
# En prod derrière le reverse proxy nginx : /api (relatif, recommandé)
API_URL=/api
